# 阿里云 / 自建 Nginx 部署：复制为 .env.production 后再 pnpm build:antd
# 前端与 API 同域，由 Nginx 将 /api 反代到本机 quote-api（8080），无需 CORS

VITE_BASE=/

# 同域反代（推荐）
VITE_GLOB_API_URL=/api

VITE_COMPRESS=gzip
VITE_PWA=false
VITE_ROUTER_HISTORY=hash
VITE_INJECT_APP_LOADING=true
VITE_ARCHIVER=false

VITE_APP_STORE_SECURE_KEY=replace-with-a-random-32-char-string
