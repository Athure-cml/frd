# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭（开发环境对接 quote-api:8080）
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 开发环境默认登录账号（仅 dev 生效，生产构建不会带入）
VITE_DEV_LOGIN_USERNAME=vben
VITE_DEV_LOGIN_PASSWORD=123456
