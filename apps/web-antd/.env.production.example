# 生产构建环境变量（在 Vercel Dashboard → Settings → Environment Variables 配置）
# 构建时注入，运行时通过 window._VBEN_ADMIN_PRO_APP_CONF_ 读取

VITE_BASE=/

# 后端 API 根地址（quote-api 无 /api 前缀，直接填 Render 域名）
# 示例：https://furuiduo-quote-api.onrender.com
VITE_GLOB_API_URL=https://YOUR-RENDER-API.onrender.com

VITE_COMPRESS=gzip
VITE_PWA=false
VITE_ROUTER_HISTORY=hash
VITE_INJECT_APP_LOADING=true
VITE_ARCHIVER=false

# 生产务必更换
VITE_APP_STORE_SECURE_KEY=replace-with-a-random-32-char-string
