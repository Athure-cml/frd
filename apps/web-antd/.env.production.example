# 生产构建环境变量
# - 阿里云 / 自建 Nginx：VITE_GLOB_API_URL=/api（默认见 .env.production）
# - Vercel + Render：在 Vercel Dashboard 设置 VITE_GLOB_API_URL=https://frd-api.onrender.com

VITE_BASE=/

# 同域 Nginx 反代（/api → quote-api:8080）
VITE_GLOB_API_URL=/api

# Render 云端示例（Vercel 环境变量覆盖，勿直接用于阿里云 dist）
# VITE_GLOB_API_URL=https://YOUR-RENDER-API.onrender.com

VITE_COMPRESS=gzip
VITE_PWA=false
VITE_ROUTER_HISTORY=hash
VITE_INJECT_APP_LOADING=true
VITE_ARCHIVER=false

# 生产务必更换
VITE_APP_STORE_SECURE_KEY=replace-with-a-random-32-char-string
