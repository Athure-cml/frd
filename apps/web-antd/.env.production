VITE_BASE=/

# 接口地址（生产在 Vercel 环境变量覆盖；quote-api 无 /api 前缀）
# 示例：https://furuiduo-quote-api.onrender.com
VITE_GLOB_API_URL=https://YOUR-RENDER-API.onrender.com

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
