VITE_BASE=/

# 阿里云 Nginx 同域反代：/api → quote-api:8080（见 quote-api/DEPLOY-ALIYUN.md）
# Vercel 部署请在 Dashboard 覆盖为 Render 地址
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=gzip

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=false
